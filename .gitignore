htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.hypothesis/
.pytest_cache/
cover/

# Translation files
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   Comment is preferred to allow sharing.
#.python-version

# pipenv
#   According to pypa/pipenv#605, it is recommended to not check in Pipfile.lock.
#   For apps, you can check it in.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is recommended to not check in poetry.lock.
#   For apps, you can check it in.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, it is recommended to not check in pdm.lock.
#   For apps, you can check it in.
#.pdm-plugins.sarif

# runtime env / virtual env
.venv/
venv/
ENV/
env/
/bin/
/lib/
/include/
/share/
pyvenv.cfg

# IDEs
.idea/
.vscode/
*.swp
*.swo

